# ---- Local runtime data & config ----
# These are normally written to the per-user data dir (%APPDATA%\UU889 or
# ~/.config/UU889), but ignore them here too in case anyone runs from the repo.
# netprobe_config.json may contain a plaintext SMTP password — never commit it.
netprobe_config.json
netprobe.db
netprobe_monitor_log.csv
netprobe_audit.log
audit.log
geo/
*.mmdb
*.mmdb.gz
lang/*.json

# ---- Virtual environments ----
.venv/
venv/
env/
ENV/

# ---- OS / editor cruft ----
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
*~
